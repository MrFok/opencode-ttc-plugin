PORT=8080
UPSTREAM_BASE_URL=https://openrouter.ai/api
UPSTREAM_API_KEY=
UPSTREAM_MAX_RETRIES=2
UPSTREAM_RETRY_BACKOFF_MS=150
UPSTREAM_RETRY_STATUS_CODES=429,500,502,503,504
UPSTREAM_STREAM_FIRST_CHUNK_TIMEOUT_MS=12000
UPSTREAM_TOTAL_TIMEOUT_MS=120000

# Optional model fallback rules.
# Format: model=fallback1,fallback2;*=defaultFallback
UPSTREAM_FALLBACKS=

# Multi-provider routing (issue #9)
# JSON object keyed by provider id.
# Example:
# UPSTREAM_PROVIDERS_JSON={"openrouter":{"baseURL":"https://openrouter.ai/api","authMode":"provider_or_client","apiKey":"","apiKeyEnv":"OPENROUTER_API_KEY","passThroughClientAuth":true,"headers":{"x-app":"token-proxy"}}}
UPSTREAM_PROVIDERS_JSON=
# JSON array of route rules. match: exact|prefix|glob
# Example:
# MODEL_ROUTE_RULES_JSON=[{"match":"prefix","value":"openrouter/","provider":"openrouter"}]
MODEL_ROUTE_RULES_JSON=
MODEL_DEFAULT_PROVIDER=default
# JSON object for fallback chains. entries can be "model" or "provider:model"
# Example:
# MODEL_FALLBACK_RULES_JSON={"gpt-4.1":["openrouter:gpt-4.1-mini"]}
MODEL_FALLBACK_RULES_JSON=
# If true, startup fails when provider auth config is invalid.
PROVIDER_CONFIG_STRICT=false

# /v1/models behavior
MODELS_SOURCE_MODE=passthrough
MODELS_CACHE_TTL_MS=30000
MODELS_ALLOWLIST=
MODELS_DENYLIST=
MODELS_ALIASES_JSON=
MODELS_STATIC_JSON=

# Optional. If set, clients must send Authorization: Bearer <PROXY_API_KEY>
PROXY_API_KEY=

# Used in Milestone 2 (compression integration)
TOKEN_COMPANY_API_KEY=
TOKEN_COMPANY_BASE_URL=https://api.thetokencompany.com
TOKEN_COMPANY_MODEL=bear-1.2
TOKEN_COMPANY_AGGRESSIVENESS=0.1
TOKEN_COMPANY_TIMEOUT_MS=2500
TOKEN_COMPANY_USE_GZIP=true
TOKEN_COMPANY_MAX_RETRIES=1
TOKEN_COMPANY_RETRY_BACKOFF_MS=100
ENABLE_COMPRESSION=true
ENABLE_EMBEDDINGS_COMPRESSION=false
COMPRESSION_MIN_CHARS=500
COMPRESS_ROLES=user
LOG_LEVEL=debug
LOG_BUFFER_SIZE=500
LOG_LOCAL_ENDPOINT=true

# Local testing mode: prefer loading .env.local when available
LOCAL_TEST_MODE=true
